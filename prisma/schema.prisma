// Partybond — Prisma schema (MVP v3.3 + squads / chat / progressive matchmaking)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum GameStatus {
  active
  coming_soon
}

enum UserState {
  idle
  in_queue
  in_match
}

enum SessionStatus {
  open
  active
  finished
}

enum SessionMode {
  casual
  competitive
}

enum PlayStyle {
  relaxed
  focused
}

enum GamePlatform {
  playstation
  xbox
  pc
  mobile
}

enum SessionSkillTier {
  beginner
  intermediate
  advanced
  veteran
}

enum MatchStatus {
  active
  finished
  expired
}

enum InteractionType {
  add_me
  already_added
  enter_lobby
  waiting
  did_not_work
}

enum GroupMemberRole {
  admin
  member
}

enum GroupInviteStatus {
  pending
  accepted
  declined
  expired
}

enum ConversationType {
  direct
  group
}

enum ScheduleFrequency {
  weekly
  biweekly
}

enum RsvpStatus {
  confirmed
  declined
  pending
}

enum SquadFillInviteStatus {
  pending
  accepted
  declined
  expired
}

enum ReportCategory {
  spam
  harassment
  offensive_language
  inappropriate_content
  other
}

enum ReportStatus {
  open
  reviewed
  dismissed
}

enum SubscriptionPlatform {
  google_play
  app_store
  manual
}

enum SubscriptionStatus {
  active
  trial
  grace
  on_hold
  paused
  canceled
  expired
  refunded
}

enum ReferralStatus {
  pending
  registered
  rewarded
  expired
}

enum AutoGroupRequestStatus {
  searching
  ready
  fulfilled
  expired
  canceled
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model Game {
  id         String     @id
  name       String
  status     GameStatus @default(coming_soon)
  maxPlayers Int        @default(4) @map("max_players")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  sessions     Session[]
  gameProfiles UserGameProfile[]
  globalQueue  GlobalQueueEntry[]
  recentAsGame RecentPlayer[]

  @@map("games")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  googleId         String?   @unique @map("google_id")
  passwordHash     String    @map("password_hash")
  name             String
  age              Int
  photoUrl         String?   @map("photo_url")
  lookingFor       String?   @map("looking_for") @db.VarChar(200)
  selectedGame     String?   @map("selected_game")
  state            UserState @default(idle)
  currentSessionId String?   @map("current_session_id")
  currentMatchId   String?   @map("current_match_id")
  fcmToken         String?   @map("fcm_token")
  locale           String    @default("en")
  lastSeenAt       DateTime? @map("last_seen_at")
  isAdmin          Boolean   @default(false) @map("is_admin")
  bannedAt         DateTime? @map("banned_at")
  banReason        String?   @map("ban_reason")
  /// Cached "premium until" date — fast O(1) gate. Mirrors the latest active subscription's
  /// `currentPeriodEnd` PLUS any referral bonus days. Authoritative source = Subscription rows.
  premiumUntil     DateTime? @map("premium_until")
  /// Referral code the user redeemed at signup (only set once, immutable).
  referredByCode   String?   @map("referred_by_code")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  gameProfiles            UserGameProfile[]
  createdSessions         Session[]                 @relation("CreatedSessions")
  queueEntries            QueueEntry[]
  globalQueueEntries      GlobalQueueEntry[]
  matchesAsA              Match[]                   @relation("MatchUserA")
  matchesAsB              Match[]                   @relation("MatchUserB")
  interactions            Interaction[]
  recentAsOwner           RecentPlayer[]            @relation("RecentAsOwner")
  recentAsPlayer          RecentPlayer[]            @relation("RecentAsPlayer")
  groupsCreated           Group[]
  groupMemberships        GroupMember[]
  groupInvitesSent        GroupInvite[]             @relation("GroupInvitesSent")
  groupInvitesReceived    GroupInvite[]             @relation("GroupInvitesReceived")
  conversationParts       ConversationParticipant[]
  messagesSent            Message[]
  pinnedMessages          PinnedMessage[]
  groupSessionRsvps       GroupSessionRsvp[]
  squadFillInvitesSent    SquadFillInvite[]         @relation("SquadFillSent")
  squadFillInvitesRecv    SquadFillInvite[]         @relation("SquadFillRecv")
  sessionSquadInvitesSent SessionSquadInvite[]      @relation("SessionSquadInvitesSent")
  sessionSquadInvitesRecv SessionSquadInvite[]      @relation("SessionSquadInvitesRecv")
  blocksInitiated         UserBlock[]               @relation("BlocksInitiated")
  blocksReceived          UserBlock[]               @relation("BlocksReceived")
  reportsFiled            UserReport[]              @relation("ReportsFiled")
  reportsReceived         UserReport[]              @relation("ReportsReceived")
  passwordResetTokens     PasswordResetToken[]
  subscriptions           Subscription[]
  referralCode            ReferralCode?
  referralsSent           Referral[]                @relation("ReferralsSent")
  referralAsInvitee       Referral?                 @relation("ReferralAsInvitee")
  autoGroupRequests       AutoGroupRequest[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model UserGameProfile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  nickname  String
  playerId  String   @map("player_id")
  platform  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@map("user_game_profiles")
}

model Session {
  id            String           @id @default(cuid())
  gameId        String           @map("game_id")
  title         String
  createdById   String           @map("created_by")
  gameMode      SessionMode      @default(casual) @map("game_mode")
  skillTier     SessionSkillTier @default(beginner) @map("skill_tier")
  playStyle     PlayStyle?       @map("play_style")
  playersNeeded Int              @map("players_needed")
  scheduledAt   DateTime         @map("scheduled_at")
  status        SessionStatus    @default(open)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  game         Game                 @relation(fields: [gameId], references: [id])
  createdBy    User                 @relation("CreatedSessions", fields: [createdById], references: [id])
  queue        QueueEntry[]
  matches      Match[]
  squadInvites SessionSquadInvite[]

  @@index([gameId, status, scheduledAt])
  @@index([gameId, status, gameMode, skillTier])
  @@map("sessions")
}

model QueueEntry {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@map("queue_entries")
}

/// Progressive matchmaking pool (per game, not per session).
model GlobalQueueEntry {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  gameId    String       @map("game_id")
  gameMode  SessionMode  @map("game_mode")
  playStyle PlayStyle    @map("play_style")
  platform  GamePlatform @default(mobile)
  joinedAt  DateTime     @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([gameId, joinedAt])
  @@map("global_queue_entries")
}

model Match {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  userAId   String      @map("user_a_id")
  userBId   String      @map("user_b_id")
  status    MatchStatus @default(active)
  startedAt DateTime    @default(now()) @map("started_at")
  endedAt   DateTime?   @map("ended_at")
  expiresAt DateTime    @map("expires_at")

  session      Session       @relation(fields: [sessionId], references: [id])
  userA        User          @relation("MatchUserA", fields: [userAId], references: [id])
  userB        User          @relation("MatchUserB", fields: [userBId], references: [id])
  interactions Interaction[]

  @@index([sessionId])
  @@index([status, expiresAt])
  @@map("matches")
}

model Interaction {
  id        String          @id @default(cuid())
  matchId   String          @map("match_id")
  userId    String          @map("user_id")
  type      InteractionType
  createdAt DateTime        @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("interactions")
}

model RecentPlayer {
  id           String   @id @default(cuid())
  ownerId      String   @map("owner_id")
  playerUserId String   @map("player_user_id")
  gameId       String   @map("game_id")
  platform     String?
  nickname     String
  photoUrl     String?  @map("photo_url")
  lastPlayedAt DateTime @map("last_played_at")

  owner  User @relation("RecentAsOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  player User @relation("RecentAsPlayer", fields: [playerUserId], references: [id], onDelete: Cascade)
  game   Game @relation(fields: [gameId], references: [id])

  @@unique([ownerId, playerUserId, gameId])
  @@index([ownerId, lastPlayedAt(sort: Desc)])
  @@map("recent_players")
}

model Group {
  id           String   @id @default(cuid())
  name         String
  photoUrl     String?  @map("photo_url")
  createdById  String   @map("created_by_id")
  /// True for groups auto-formed by the matchmaker (premium feature). Manual groups stay false.
  isAutoFormed Boolean  @default(false) @map("is_auto_formed")
  createdAt    DateTime @default(now()) @map("created_at")

  createdBy        User              @relation(fields: [createdById], references: [id])
  members          GroupMember[]
  invites          GroupInvite[]
  schedules        GroupSchedule[]
  sessions         GroupSession[]
  conversation     Conversation?
  squadFillInvites SquadFillInvite[]
  autoGroupRequest AutoGroupRequest?

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(cuid())
  groupId  String          @map("group_id")
  userId   String          @map("user_id")
  role     GroupMemberRole @default(member)
  joinedAt DateTime        @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupInvite {
  id          String            @id @default(cuid())
  groupId     String            @map("group_id")
  inviterId   String            @map("inviter_id")
  inviteeId   String            @map("invitee_id")
  status      GroupInviteStatus @default(pending)
  expiresAt   DateTime          @map("expires_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  respondedAt DateTime?         @map("responded_at")

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter User  @relation("GroupInvitesSent", fields: [inviterId], references: [id])
  invitee User  @relation("GroupInvitesReceived", fields: [inviteeId], references: [id])

  @@index([inviteeId, status])
  @@map("group_invites")
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType
  groupId   String?          @unique @map("group_id")
  createdAt DateTime         @default(now()) @map("created_at")

  group        Group?                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]
  pinned       PinnedMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  body           String   @db.Text
  replyToId      String?  @map("reply_to_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User           @relation(fields: [senderId], references: [id])
  replyTo      Message?       @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]      @relation("MessageReplies")
  pinned       PinnedMessage?

  @@index([conversationId, createdAt])
  @@map("messages")
}

model PinnedMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  messageId      String   @unique @map("message_id")
  pinnedById     String   @map("pinned_by_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy     User         @relation(fields: [pinnedById], references: [id])

  @@map("pinned_messages")
}

model GroupSchedule {
  id        String            @id @default(cuid())
  groupId   String            @map("group_id")
  dayOfWeek Int               @map("day_of_week")
  timeLocal String            @map("time_local")
  frequency ScheduleFrequency @default(weekly)
  timezone  String            @default("America/Sao_Paulo")
  createdAt DateTime          @default(now()) @map("created_at")

  group    Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sessions GroupSession[]

  @@map("group_schedules")
}

model GroupSession {
  id         String   @id @default(cuid())
  groupId    String   @map("group_id")
  scheduleId String?  @map("schedule_id")
  startsAt   DateTime @map("starts_at")
  createdAt  DateTime @default(now()) @map("created_at")

  group            Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  schedule         GroupSchedule?     @relation(fields: [scheduleId], references: [id])
  rsvps            GroupSessionRsvp[]
  squadFillInvites SquadFillInvite[]

  @@index([groupId, startsAt])
  @@map("group_sessions")
}

model GroupSessionRsvp {
  id        String     @id @default(cuid())
  sessionId String     @map("session_id")
  userId    String     @map("user_id")
  status    RsvpStatus @default(pending)
  updatedAt DateTime   @updatedAt @map("updated_at")

  session GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("group_session_rsvps")
}

model SquadFillInvite {
  id        String                @id @default(cuid())
  groupId   String                @map("group_id")
  sessionId String?               @map("session_id")
  inviterId String                @map("inviter_id")
  inviteeId String                @map("invitee_id")
  status    SquadFillInviteStatus @default(pending)
  expiresAt DateTime              @map("expires_at")
  createdAt DateTime              @default(now()) @map("created_at")

  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  session GroupSession? @relation(fields: [sessionId], references: [id])
  inviter User          @relation("SquadFillSent", fields: [inviterId], references: [id])
  invitee User          @relation("SquadFillRecv", fields: [inviteeId], references: [id])

  @@index([inviteeId, status])
  @@map("squad_fill_invites")
}

/// Invite friends / recent players to a play session squad (home → criar equipe).
model SessionSquadInvite {
  id        String                @id @default(cuid())
  sessionId String                @map("session_id")
  inviterId String                @map("inviter_id")
  inviteeId String                @map("invitee_id")
  status    SquadFillInviteStatus @default(pending)
  expiresAt DateTime              @map("expires_at")
  createdAt DateTime              @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inviter User    @relation("SessionSquadInvitesSent", fields: [inviterId], references: [id])
  invitee User    @relation("SessionSquadInvitesRecv", fields: [inviteeId], references: [id])

  @@unique([sessionId, inviteeId])
  @@index([inviteeId, status])
  @@map("session_squad_invites")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("user_blocks")
}

model UserReport {
  id           String         @id @default(cuid())
  reporterId   String         @map("reporter_id")
  reportedId   String         @map("reported_id")
  category     ReportCategory
  details      String?        @db.Text
  status       ReportStatus   @default(open)
  adminNote    String?        @map("admin_note") @db.Text
  resolvedAt   DateTime?      @map("resolved_at")
  resolvedById String?        @map("resolved_by_id")
  createdAt    DateTime       @default(now()) @map("created_at")

  reporter User @relation("ReportsFiled", fields: [reporterId], references: [id])
  reported User @relation("ReportsReceived", fields: [reportedId], references: [id])

  @@index([reportedId, createdAt])
  @@index([status, createdAt])
  @@map("user_reports")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  name      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([name, createdAt])
  @@map("analytics_events")
}

// -----------------------------------------------------------------------------
// Premium / Billing
// -----------------------------------------------------------------------------

/// Persisted record of a Google Play / App Store / manually-granted subscription.
/// `purchaseToken` is unique per platform: the same token re-validates the same row.
model Subscription {
  id               String               @id @default(cuid())
  userId           String               @map("user_id")
  platform         SubscriptionPlatform
  productId        String               @map("product_id")
  /// Google Play purchaseToken (subscription) or Apple originalTransactionId.
  purchaseToken    String               @map("purchase_token")
  /// "originalOrderId" / linked purchase chain — useful for renewals and upgrades.
  originalOrderId  String?              @map("original_order_id")
  status           SubscriptionStatus   @default(active)
  autoRenewing     Boolean              @default(true) @map("auto_renewing")
  startedAt        DateTime             @default(now()) @map("started_at")
  /// Authoritative current period end as reported by the store. Used to compute premium gates.
  currentPeriodEnd DateTime             @map("current_period_end")
  canceledAt       DateTime?            @map("canceled_at")
  /// Snapshot of the latest provider verification payload (for debugging / audits).
  rawPayload       Json?                @map("raw_payload")
  lastVerifiedAt   DateTime             @default(now()) @map("last_verified_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, purchaseToken])
  @@index([userId, status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

/// One stable invite/referral code per user. Code is short, URL-safe, and case-insensitive.
model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("referral_codes")
}

/// A single "X invited Y" event. Created when the invitee redeems a code (either at
/// signup or via the share-link landing page). `rewardGrantedAt` flips when the inviter
/// has been credited (premium days) and is idempotent.
model Referral {
  id              String         @id @default(cuid())
  inviterId       String         @map("inviter_id")
  inviteeId       String?        @unique @map("invitee_id")
  code            String
  status          ReferralStatus @default(pending)
  rewardDays      Int            @default(0) @map("reward_days")
  rewardGrantedAt DateTime?      @map("reward_granted_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  inviter User  @relation("ReferralsSent", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User? @relation("ReferralAsInvitee", fields: [inviteeId], references: [id], onDelete: SetNull)

  @@index([inviterId, status])
  @@index([code])
  @@map("referrals")
}

// -----------------------------------------------------------------------------
// Auto Group Formation (premium)
// -----------------------------------------------------------------------------

/// Tracks an in-flight "form me a group of N players for game X" request.
/// The matcher fills slots by inviting candidates picked from the global queue and
/// recent-players pools. One open request per user per game at a time.
model AutoGroupRequest {
  id            String                 @id @default(cuid())
  userId        String                 @map("user_id")
  groupId       String                 @unique @map("group_id")
  gameId        String                 @map("game_id")
  gameMode      SessionMode            @map("game_mode")
  playStyle     PlayStyle              @map("play_style")
  skillTier     SessionSkillTier       @map("skill_tier")
  playersNeeded Int                    @map("players_needed")
  minAge        Int?                   @map("min_age")
  maxAge        Int?                   @map("max_age")
  status        AutoGroupRequestStatus @default(searching)
  expiresAt     DateTime               @map("expires_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([userId, status])
  @@map("auto_group_requests")
}
