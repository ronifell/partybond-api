// Partybond — Prisma schema
// PostgreSQL, modelled after BLUEPRINT v3.3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum GameStatus {
  active
  coming_soon
}

enum UserState {
  idle
  in_queue
  in_match
}

enum SessionStatus {
  open
  active
  finished
}

enum SessionMode {
  casual
  competitive
}

enum MatchStatus {
  active
  finished
  expired
}

enum InteractionType {
  add_me
  already_added
  enter_lobby
  waiting
  did_not_work
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model Game {
  id          String     @id // e.g. "free_fire"
  name        String
  status      GameStatus @default(coming_soon)
  maxPlayers  Int        @default(4)  @map("max_players")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  sessions    Session[]
  gameProfiles UserGameProfile[]

  @@map("games")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")

  name          String
  age           Int
  photoUrl      String?    @map("photo_url")

  selectedGame  String?    @map("selected_game")
  state         UserState  @default(idle)

  currentSessionId String?  @map("current_session_id")
  currentMatchId   String?  @map("current_match_id")

  fcmToken      String?    @map("fcm_token")
  locale        String     @default("en")

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  gameProfiles   UserGameProfile[]
  createdSessions Session[]        @relation("CreatedSessions")
  queueEntries   QueueEntry[]
  matchesAsA     Match[]           @relation("MatchUserA")
  matchesAsB     Match[]           @relation("MatchUserB")
  interactions   Interaction[]

  @@map("users")
}

// One row per (user, game). Holds nickname + player_id for that game.
model UserGameProfile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  nickname  String
  playerId  String   @map("player_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@map("user_game_profiles")
}

model Session {
  id            String        @id @default(cuid())
  gameId        String        @map("game_id")
  title         String
  createdById   String        @map("created_by")
  gameMode      SessionMode   @default(casual) @map("game_mode")
  playersNeeded Int           @map("players_needed")
  scheduledAt   DateTime      @map("scheduled_at")
  status        SessionStatus @default(open)

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  game          Game          @relation(fields: [gameId], references: [id])
  createdBy     User          @relation("CreatedSessions", fields: [createdById], references: [id])
  queue         QueueEntry[]
  matches       Match[]

  @@index([gameId, status, scheduledAt])
  @@map("sessions")
}

model QueueEntry {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  userId     String   @map("user_id")
  joinedAt   DateTime @default(now()) @map("joined_at")

  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@map("queue_entries")
}

model Match {
  id         String      @id @default(cuid())
  sessionId  String      @map("session_id")
  userAId    String      @map("user_a_id")
  userBId    String      @map("user_b_id")
  status     MatchStatus @default(active)
  startedAt  DateTime    @default(now()) @map("started_at")
  endedAt    DateTime?   @map("ended_at")
  expiresAt  DateTime    @map("expires_at")

  session    Session     @relation(fields: [sessionId], references: [id])
  userA      User        @relation("MatchUserA", fields: [userAId], references: [id])
  userB      User        @relation("MatchUserB", fields: [userBId], references: [id])
  interactions Interaction[]

  @@index([sessionId])
  @@index([status, expiresAt])
  @@map("matches")
}

model Interaction {
  id        String          @id @default(cuid())
  matchId   String          @map("match_id")
  userId    String          @map("user_id")
  type      InteractionType
  createdAt DateTime        @default(now()) @map("created_at")

  match     Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("interactions")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  name      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([name, createdAt])
  @@map("analytics_events")
}
