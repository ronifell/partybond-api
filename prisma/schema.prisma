// Partybond — Prisma schema (MVP v3.3 + squads / chat / progressive matchmaking)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum GameStatus {
  active
  coming_soon
}

enum UserState {
  idle
  in_queue
  in_match
}

enum SessionStatus {
  open
  active
  finished
}

enum SessionMode {
  casual
  competitive
}

enum PlayStyle {
  relaxed
  focused
}

enum SessionSkillTier {
  beginner
  intermediate
  advanced
  veteran
}

enum MatchStatus {
  active
  finished
  expired
}

enum InteractionType {
  add_me
  already_added
  enter_lobby
  waiting
  did_not_work
}

enum GroupMemberRole {
  admin
  member
}

enum GroupInviteStatus {
  pending
  accepted
  declined
  expired
}

enum ConversationType {
  direct
  group
}

enum ScheduleFrequency {
  weekly
  biweekly
}

enum RsvpStatus {
  confirmed
  declined
  pending
}

enum SquadFillInviteStatus {
  pending
  accepted
  declined
  expired
}

enum ReportCategory {
  spam
  harassment
  offensive_language
  inappropriate_content
  other
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model Game {
  id           String     @id
  name         String
  status       GameStatus @default(coming_soon)
  maxPlayers   Int        @default(4) @map("max_players")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  sessions     Session[]
  gameProfiles UserGameProfile[]
  globalQueue  GlobalQueueEntry[]
  recentAsGame RecentPlayer[]

  @@map("games")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String    @map("password_hash")
  name             String
  age              Int
  photoUrl         String?   @map("photo_url")
  lookingFor       String?   @map("looking_for") @db.VarChar(200)
  selectedGame     String?   @map("selected_game")
  state            UserState @default(idle)
  currentSessionId String?   @map("current_session_id")
  currentMatchId   String?   @map("current_match_id")
  fcmToken         String?   @map("fcm_token")
  locale           String    @default("en")
  lastSeenAt       DateTime? @map("last_seen_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  gameProfiles          UserGameProfile[]
  createdSessions       Session[]                 @relation("CreatedSessions")
  queueEntries          QueueEntry[]
  globalQueueEntries    GlobalQueueEntry[]
  matchesAsA            Match[]                   @relation("MatchUserA")
  matchesAsB            Match[]                   @relation("MatchUserB")
  interactions          Interaction[]
  recentAsOwner         RecentPlayer[]            @relation("RecentAsOwner")
  recentAsPlayer        RecentPlayer[]            @relation("RecentAsPlayer")
  groupsCreated         Group[]
  groupMemberships      GroupMember[]
  groupInvitesSent      GroupInvite[]             @relation("GroupInvitesSent")
  groupInvitesReceived  GroupInvite[]             @relation("GroupInvitesReceived")
  conversationParts     ConversationParticipant[]
  messagesSent          Message[]
  pinnedMessages        PinnedMessage[]
  groupSessionRsvps     GroupSessionRsvp[]
  squadFillInvitesSent  SquadFillInvite[]         @relation("SquadFillSent")
  squadFillInvitesRecv  SquadFillInvite[]         @relation("SquadFillRecv")
  blocksInitiated       UserBlock[]               @relation("BlocksInitiated")
  blocksReceived        UserBlock[]               @relation("BlocksReceived")
  reportsFiled          UserReport[]              @relation("ReportsFiled")
  reportsReceived       UserReport[]              @relation("ReportsReceived")

  @@map("users")
}

model UserGameProfile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  gameId    String   @map("game_id")
  nickname  String
  playerId  String   @map("player_id")
  platform  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@map("user_game_profiles")
}

model Session {
  id            String           @id @default(cuid())
  gameId        String           @map("game_id")
  title         String
  createdById   String           @map("created_by")
  gameMode      SessionMode      @default(casual) @map("game_mode")
  skillTier     SessionSkillTier @default(beginner) @map("skill_tier")
  playStyle     PlayStyle?       @map("play_style")
  playersNeeded Int              @map("players_needed")
  scheduledAt   DateTime         @map("scheduled_at")
  status        SessionStatus    @default(open)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  game      Game         @relation(fields: [gameId], references: [id])
  createdBy User         @relation("CreatedSessions", fields: [createdById], references: [id])
  queue     QueueEntry[]
  matches   Match[]

  @@index([gameId, status, scheduledAt])
  @@index([gameId, status, gameMode, skillTier])
  @@map("sessions")
}

model QueueEntry {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@map("queue_entries")
}

/// Progressive matchmaking pool (per game, not per session).
model GlobalQueueEntry {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  gameId    String      @map("game_id")
  gameMode  SessionMode @map("game_mode")
  playStyle PlayStyle   @map("play_style")
  joinedAt  DateTime    @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([gameId, joinedAt])
  @@map("global_queue_entries")
}

model Match {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  userAId   String      @map("user_a_id")
  userBId   String      @map("user_b_id")
  status    MatchStatus @default(active)
  startedAt DateTime    @default(now()) @map("started_at")
  endedAt   DateTime?   @map("ended_at")
  expiresAt DateTime    @map("expires_at")

  session      Session       @relation(fields: [sessionId], references: [id])
  userA        User          @relation("MatchUserA", fields: [userAId], references: [id])
  userB        User          @relation("MatchUserB", fields: [userBId], references: [id])
  interactions Interaction[]

  @@index([sessionId])
  @@index([status, expiresAt])
  @@map("matches")
}

model Interaction {
  id        String          @id @default(cuid())
  matchId   String          @map("match_id")
  userId    String          @map("user_id")
  type      InteractionType
  createdAt DateTime        @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("interactions")
}

model RecentPlayer {
  id           String   @id @default(cuid())
  ownerId      String   @map("owner_id")
  playerUserId String   @map("player_user_id")
  gameId       String   @map("game_id")
  platform     String?
  nickname     String
  photoUrl     String?  @map("photo_url")
  lastPlayedAt DateTime @map("last_played_at")

  owner  User @relation("RecentAsOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  player User @relation("RecentAsPlayer", fields: [playerUserId], references: [id], onDelete: Cascade)
  game   Game @relation(fields: [gameId], references: [id])

  @@unique([ownerId, playerUserId, gameId])
  @@index([ownerId, lastPlayedAt(sort: Desc)])
  @@map("recent_players")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  photoUrl    String?  @map("photo_url")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy     User           @relation(fields: [createdById], references: [id])
  members       GroupMember[]
  invites       GroupInvite[]
  schedules     GroupSchedule[]
  sessions      GroupSession[]
  conversation  Conversation?
  squadFillInvites SquadFillInvite[]

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(cuid())
  groupId  String          @map("group_id")
  userId   String          @map("user_id")
  role     GroupMemberRole @default(member)
  joinedAt DateTime        @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupInvite {
  id          String            @id @default(cuid())
  groupId     String            @map("group_id")
  inviterId   String            @map("inviter_id")
  inviteeId   String            @map("invitee_id")
  status      GroupInviteStatus @default(pending)
  expiresAt   DateTime          @map("expires_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  respondedAt DateTime?         @map("responded_at")

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter User  @relation("GroupInvitesSent", fields: [inviterId], references: [id])
  invitee User  @relation("GroupInvitesReceived", fields: [inviteeId], references: [id])

  @@index([inviteeId, status])
  @@map("group_invites")
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType
  groupId   String?          @unique @map("group_id")
  createdAt DateTime         @default(now()) @map("created_at")

  group        Group?                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]
  pinned       PinnedMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  body           String   @db.Text
  replyToId      String?  @map("reply_to_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReplies")
  pinned       PinnedMessage?

  @@index([conversationId, createdAt])
  @@map("messages")
}

model PinnedMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  messageId      String   @unique @map("message_id")
  pinnedById     String   @map("pinned_by_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy     User         @relation(fields: [pinnedById], references: [id])

  @@map("pinned_messages")
}

model GroupSchedule {
  id        String            @id @default(cuid())
  groupId   String            @map("group_id")
  dayOfWeek Int               @map("day_of_week")
  timeLocal String            @map("time_local")
  frequency ScheduleFrequency @default(weekly)
  timezone  String            @default("America/Sao_Paulo")
  createdAt DateTime          @default(now()) @map("created_at")

  group    Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sessions GroupSession[]

  @@map("group_schedules")
}

model GroupSession {
  id         String   @id @default(cuid())
  groupId    String   @map("group_id")
  scheduleId String?  @map("schedule_id")
  startsAt   DateTime @map("starts_at")
  createdAt  DateTime @default(now()) @map("created_at")

  group    Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  schedule GroupSchedule?     @relation(fields: [scheduleId], references: [id])
  rsvps    GroupSessionRsvp[]
  squadFillInvites SquadFillInvite[]

  @@index([groupId, startsAt])
  @@map("group_sessions")
}

model GroupSessionRsvp {
  id        String     @id @default(cuid())
  sessionId String     @map("session_id")
  userId    String     @map("user_id")
  status    RsvpStatus @default(pending)
  updatedAt DateTime   @updatedAt @map("updated_at")

  session GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("group_session_rsvps")
}

model SquadFillInvite {
  id        String                @id @default(cuid())
  groupId   String                @map("group_id")
  sessionId String?               @map("session_id")
  inviterId String                @map("inviter_id")
  inviteeId String                @map("invitee_id")
  status    SquadFillInviteStatus @default(pending)
  expiresAt DateTime              @map("expires_at")
  createdAt DateTime              @default(now()) @map("created_at")

  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  session GroupSession? @relation(fields: [sessionId], references: [id])
  inviter User          @relation("SquadFillSent", fields: [inviterId], references: [id])
  invitee User          @relation("SquadFillRecv", fields: [inviteeId], references: [id])

  @@index([inviteeId, status])
  @@map("squad_fill_invites")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("user_blocks")
}

model UserReport {
  id         String         @id @default(cuid())
  reporterId String         @map("reporter_id")
  reportedId String         @map("reported_id")
  category   ReportCategory
  details    String?        @db.Text
  createdAt  DateTime       @default(now()) @map("created_at")

  reporter User @relation("ReportsFiled", fields: [reporterId], references: [id])
  reported User @relation("ReportsReceived", fields: [reportedId], references: [id])

  @@index([reportedId, createdAt])
  @@map("user_reports")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  name      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([name, createdAt])
  @@map("analytics_events")
}
