# --- Server ---
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
CLIENT_ORIGINS=http://localhost:8081,http://localhost:19006,exp://

# --- Database (PostgreSQL) ---
# Local Postgres example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/partybond?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/partybond?schema=public
#
# Supabase example (recommended for Node.js + Prisma):
#   Use the SESSION pooler (port 5432) for both DATABASE_URL and DIRECT_URL.
#   The transaction pooler (port 6543) breaks Prisma's interactive transactions.
#   The session pooler keeps a persistent connection per client and supports
#   transactions natively.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?connection_limit=10&pool_timeout=30&connect_timeout=15
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# --- Auth ---
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=30d

# Password reset (optional — without RESEND_API_KEY, reset links are logged server-side only)
RESEND_API_KEY=
EMAIL_FROM=Partybond <onboarding@resend.dev>
RESET_LINK_BASE=partybond://reset-password

# --- Firebase Cloud Messaging (optional in dev) ---
# Paste the JSON content of your service account here (single-line) or leave empty to disable push.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
