# --- Server ---

NODE_ENV=development

PORT=4000

APP_URL=http://localhost:4000

CLIENT_ORIGINS=http://localhost:8081,http://localhost:19006,exp://



# --- Database (PostgreSQL) ---

# Local Postgres example:

# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/partybond?schema=public

# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/partybond?schema=public

#

# Supabase example (recommended for Node.js + Prisma):

#   Use the SESSION pooler (port 5432) for both DATABASE_URL and DIRECT_URL.

#   The transaction pooler (port 6543) breaks Prisma's interactive transactions.

#   The session pooler keeps a persistent connection per client and supports

#   transactions natively.

DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?connection_limit=10&pool_timeout=30&connect_timeout=15

DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres



# --- Auth ---

JWT_SECRET=replace-this-with-a-long-random-string

JWT_EXPIRES_IN=30d

# Google Sign-In (OAuth 2.0 client IDs from Google Cloud Console)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com



# Password reset email (Gmail SMTP + App Password)

# Create an App Password: Google Account → Security → 2-Step Verification → App passwords

# Without MAIL_USERNAME + MAIL_PASSWORD, codes are logged in the server console only.

MAIL_HOST=smtp.gmail.com

MAIL_PORT=587

MAIL_USERNAME=your.email@gmail.com

# 16 characters, no spaces (e.g. abcdefghijklmnop). Create at https://myaccount.google.com/apppasswords
MAIL_PASSWORD=your-16-char-app-password

MAIL_FROM_NAME=Partybond



# --- Firebase Cloud Messaging (optional in dev) ---

# Paste the JSON content of your service account here (single-line) or leave empty to disable push.

FIREBASE_SERVICE_ACCOUNT_JSON=



# --- Google Play Billing (Premium subscriptions) ---

# Service account JSON (single line) with "Financial data" + "Manage orders & subscriptions"
# in Google Play Console → Setup → API access. Leave empty in dev to disable real verification.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Android package name registered in Play Console (must match app.json `android.package`).
GOOGLE_PLAY_PACKAGE_NAME=com.partybond.app

# Comma-separated list of subscription product IDs that unlock Premium.
# Default: a single monthly plan. Add more (e.g. .yearly) if/when you offer them.
PREMIUM_PRODUCT_IDS=partybond.premium.monthly



# --- Referrals (invite-a-friend → Play Store) ---

# Public-facing landing page that resolves invite codes. Must be a URL the friend can open
# from a chat/sms. Typically points back at this API (e.g. https://api.partybond.com/i).
# The "/i/<code>" route below redirects Android → Play Store with install referrer,
# iOS → App Store, desktop → small landing page.
INVITE_BASE_URL=http://localhost:4000/i

# Where iOS users get sent from the invite landing page. Update once published on the App Store.
APP_STORE_URL=https://apps.apple.com/app/id0000000000

# How many free Premium days the inviter gets when an invitee completes registration.
REFERRAL_REWARD_DAYS=7



# --- Uploads ---

UPLOAD_DIR=uploads

MAX_UPLOAD_SIZE_MB=5

# Game thumbnails (served at GET /game-images/:id). Optional — when unset, the API auto-detects:
#   1. ../partybond-admin/public/games  (production layout)
#   2. ../Admin/public/games            (local repo layout)
#   3. ./game-images                    (fallback inside the API folder)
# Set explicitly when admin and API are not sibling directories:
# GAME_IMAGES_DIR=/home/ubuntu/partybond-admin/public/games

